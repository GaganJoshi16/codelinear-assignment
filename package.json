{
  "name": "gagandeep-assignment",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check package.json README.md eslint.config.js vite.config.ts tsconfig.json tsconfig.app.json tsconfig.node.json index.html .github/workflows/ci.yml .prettierrc .vscode/extensions.json .vscode/settings.json src/vite-env.d.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.13.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "6.3.5",
    "vitest": "^3.2.4"
  }
}
